      "question": "If the price of sugar increases by 10%, by what percent should a family reduce consumption to keep expenditure unchanged?",
      "options": [
        "9.09%",
        "10%",
        "11%",
        "10.5%"
      ],
      "correctAnswer": "9.09%",
      "explanation": "Reduction = 10/110 × 100 ≈ 9.09%."
    },
