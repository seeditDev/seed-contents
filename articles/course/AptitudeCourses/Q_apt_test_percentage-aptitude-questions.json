      "id": "3",
      "question": "A number is first increased by 20% and then decreased by 20%. The net change is:",
      "options": [
        "-4%",
        "-2%",
        "0%",
        "+4%"
      ],
      "correctAnswer": "-4%",
      "explanation": "Net effect = 100×1.2×0.8 = 96. Net change = -4%."
    },
    {
      "id": "4",
      "question": "What percentage of 2/7 is 1/35?",
      "options": [
        "10%",
        "2.5%",
        "5%",
        "20%"
      ],
      "correctAnswer": "10%",
      "explanation": "(1/35)/(2/7) × 100 = (1/35)×(7/2)×100 = 10%."
    },
    {
      "id": "5",
      "question": "In an election, a candidate gets 65% of votes polled and wins by 300 votes. What is the total number of votes polled?",
      "options": [
        "750",
        "1000",
        "1200",
        "1500"
      ],
      "correctAnswer": "1000",
      "explanation": "65% - 35% = 30% = 300 votes. Total = 300/0.30 = 1000."
    },
    {
      "id": "6",
      "question": "A shopkeeper sells an item at 20% profit. If cost price increases by 10% but selling price remains same, what is new profit %?",
      "options": [
        "(20/11)×10%",
        "9.09%",
        "10%",
        "(100/11)%"
      ],
      "correctAnswer": "(100/11)%",
      "explanation": "Old SP=1.2C. New CP=1.1C. New profit=(1.2C-1.1C)/1.1C = 0.1/1.1 ≈ 9.09% = 100/11%."
    },
    {
      "id": "7",
      "question": "If A's salary is 25% more than B's salary, then B's salary is how much % less than A's?",
      "options": [
        "15%",
        "20%",
        "25%",
        "30%"
      ],
      "correctAnswer": "20%",
      "explanation": "B = A/1.25. B is less than A by 0.25/1.25 = 20%."
    },
    {
      "id": "8",
      "question": "The population of a town increased by 10% in 2022 and decreased by 10% in 2023. If the present population is 99000, what was it in 2021?",
