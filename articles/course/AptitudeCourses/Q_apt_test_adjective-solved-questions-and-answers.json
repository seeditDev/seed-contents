{
  "id": "Q_apt_test_adjective-solved-questions-and-answers",
  "name": "Adjectives Practice Test",
  "section": "aptitude",
  "topic": "adjective-solved-questions-and-answers",
  "questions": [
    {
      "id": "1",
      "question": "Identify the adjective: 'The tall man walked quickly.'",
      "options": [
        "tall",
        "man",
        "walked",
        "quickly"
      ],
      "correctAnswer": "tall",
      "explanation": "'Tall' describes the man and is an adjective."
    },
    {
      "id": "2",
      "question": "What type of adjective is 'many' in 'I have many books'?",
      "options": [
        "Descriptive",
        "Numeral",
        "Possessive",
        "Quantitative"
      ],
      "correctAnswer": "Quantitative",
      "explanation": "'Many' is a quantitative adjective showing the quantity."
    },
    {
      "id": "3",
      "question": "Choose the correct comparative form of 'good':",
      "options": [
        "Gooder",
        "More good",
        "Better",
        "Bester"
      ],
      "correctAnswer": "Better",
      "explanation": "Good → Better (irregular comparative form)."
    },
    {
      "id": "4",
      "question": "Which is the superlative form of 'bad'?",
      "options": [
        "Worse",
        "Baddest",
        "Most bad",
        "Worst"
      ],
      "correctAnswer": "Worst",
      "explanation": "Bad → Worse → Worst (irregular forms)."
    },
    {
      "id": "5",
      "question": "Find the adjective: 'She bought a beautiful red silk sari.'",
      "options": [
        "beautiful",
        "red",
        "silk",
        "All of these"
      ],
      "correctAnswer": "All of these",
      "explanation": "Beautiful (descriptive), red (descriptive), silk (material) all modify 'sari'."
    },
    {
      "id": "6",
      "question": "Identify the correct usage:",
      "options": [
        "She is more smarter than him",
        "She is smarter than him",
        "She is most smart than him",
        "She is very smarter than him"
      ],
      "correctAnswer": "She is smarter than him",
      "explanation": "'Smarter' is already the comparative. Don't add 'more'."
    },
    {
      "id": "7",
      "question": "What kind of adjective is 'this' in 'This book is mine'?",
      "options": [
        "Possessive",
        "Interrogative",
        "Demonstrative",
        "Distributive"
      ],
      "correctAnswer": "Demonstrative",
      "explanation": "This/that/these/those are demonstrative adjectives."
    }
  ]
}