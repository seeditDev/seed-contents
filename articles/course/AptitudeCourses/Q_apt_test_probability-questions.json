  "questions": [
    {
      "id": "1",
      "question": "A bag contains 4 red and 6 blue balls. One ball is drawn at random. Probability it is red is:",
      "options": [
        "2/5",
        "3/5",
        "1/4",
        "3/4"
      ],
      "correctAnswer": "2/5",
      "explanation": "P(red) = 4/10 = 2/5."
    },
    {
      "id": "2",
      "question": "Two dice are thrown. Probability that the sum is 7 is:",
      "options": [
        "1/6",
        "1/7",
        "5/36",
        "6/36"
      ],
      "correctAnswer": "1/6",
      "explanation": "Favorable: (1,6),(2,5),(3,4),(4,3),(5,2),(6,1) = 6. P=6/36=1/6."
    },
    {
      "id": "3",
      "question": "A card is drawn from a standard deck. Probability of drawing a face card is:",
      "options": [
        "3/13",
        "4/13",
        "12/52",
        "1/4"
      ],
      "correctAnswer": "3/13",
      "explanation": "Face cards = 12 (J,Q,K × 4 suits). P = 12/52 = 3/13."
    },
    {
      "id": "4",
      "question": "Two coins are tossed. What is the probability of getting at least one head?",
      "options": [
        "1/2",
        "1/4",
        "3/4",
        "1"
      ],
      "correctAnswer": "3/4",
      "explanation": "P(at least 1 head) = 1 - P(no head) = 1-1/4 = 3/4."
    },
    {
      "id": "5",
      "question": "From a bag with 5 red, 3 green, 2 blue balls, what is the probability of drawing a green or blue ball?",
      "options": [
        "1/2",
        "2/5",
        "3/10",
        "5/10"
      ],
      "correctAnswer": "1/2",
      "explanation": "P(green or blue) = (3+2)/10 = 5/10 = 1/2."
    },
    {
      "id": "6",
      "question": "What is the probability that a two-digit number selected at random is a multiple of 3?",
      "options": [
        "3/9",
        "30/90",
        "1/3",
        "30/89"
      ],
      "correctAnswer": "1/3",
      "explanation": "Two-digit multiples of 3: from 12 to 99 = 30 numbers. Total two-digit = 90. P=30/90=1/3."
    },
    {
      "id": "7",
      "question": "Two events A and B are independent. P(A)=0.4, P(B)=0.5. Find P(A∩B).",
      "options": [
        "0.1",
        "0.2",
        "0.9",
        "0.45"
      ],
      "correctAnswer": "0.2",
      "explanation": "P(A∩B) = P(A)×P(B) = 0.4×0.5 = 0.2."
    }
  ]
}