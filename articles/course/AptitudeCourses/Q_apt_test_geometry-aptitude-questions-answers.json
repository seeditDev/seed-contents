      "question": "What is the sum of interior angles of a hexagon?",
      "options": [
        "360°",
        "540°",
        "720°",
        "900°"
      ],
      "correctAnswer": "720°",
      "explanation": "Sum = (n-2)×180 = 4×180 = 720°."
    },
    {
      "id": "2",
      "question": "Two complementary angles are in ratio 2:3. Find the smaller angle.",
      "options": [
        "36°",
        "40°",
        "54°",
        "60°"
      ],
      "correctAnswer": "36°",
      "explanation": "2x+3x=90. x=18. Smaller=2×18=36°."
    },
    {
      "id": "3",
      "question": "A parallelogram has adjacent sides 8 cm and 6 cm. Find the perimeter.",
      "options": [
        "20 cm",
        "24 cm",
        "28 cm",
        "48 cm"
      ],
      "correctAnswer": "28 cm",
      "explanation": "Perimeter = 2(8+6) = 28 cm."
    },
    {
      "id": "4",
      "question": "The angles of a triangle are in ratio 2:3:4. Find the largest angle.",
      "options": [
        "60°",
        "80°",
        "90°",
        "100°"
      ],
      "correctAnswer": "80°",
      "explanation": "2x+3x+4x=180. 9x=180. x=20. Largest=4×20=80°."
    },
    {
      "id": "5",
      "question": "A circle and a square have the same perimeter. If the radius of the circle is 7 cm, find the side of the square. (π=22/7)",
      "options": [
        "10 cm",
        "11 cm",
        "12 cm",
        "14 cm"
      ],
      "correctAnswer": "11 cm",
      "explanation": "Circumference=2×(22/7)×7=44 cm. Square side=44/4=11 cm."
    },
