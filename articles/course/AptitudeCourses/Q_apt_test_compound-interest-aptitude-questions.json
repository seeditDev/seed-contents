  "name": "Compound Interest Practice Test",
  "section": "aptitude",
  "topic": "compound-interest-aptitude-questions",
  "questions": [
    {
      "id": "1",
      "question": "What is the compound interest on Rs. 5000 for 2 years at 10% per annum?",
      "options": [
        "Rs. 950",
        "Rs. 1000",
        "Rs. 1050",
        "Rs. 1100"
      ],
      "correctAnswer": "Rs. 1050",
      "explanation": "CI = 5000×(1.1)²-5000 = 5000×1.21-5000 = 6050-5000 = 1050."
    },
    {
      "id": "2",
      "question": "At what compound interest rate will Rs. 1000 become Rs. 1331 in 3 years?",
      "options": [
        "8%",
        "10%",
        "12%",
        "14%"
      ],
      "correctAnswer": "10%",
      "explanation": "1000×(1+r)³ = 1331 = 1000×(1.1)³. So r = 10%."
    },
    {
      "id": "3",
      "question": "The difference between CI and SI for 2 years at 10% on Rs. 5000 is:",
      "options": [
        "Rs. 50",
        "Rs. 75",
        "Rs. 100",
        "Rs. 150"
      ],
      "correctAnswer": "Rs. 50",
      "explanation": "Diff = P×(r/100)² = 5000×0.01 = 50."
    },
    {
      "id": "4",
      "question": "A sum of money placed at CI doubles itself in 5 years. In how many years will it become 32 times?",
      "options": [
        "15",
        "20",
        "25",
        "30"
      ],
      "correctAnswer": "25",
      "explanation": "2P in 5 years → 32P = 2⁵P in 5×5 = 25 years."
    },
    {
      "id": "5",
      "question": "The CI on Rs. 10,000 for 3 years at 10% per annum compounded annually is:",
      "options": [
        "Rs. 2310",
        "Rs. 3000",
        "Rs. 3100",
        "Rs. 3310"
      ],
      "correctAnswer": "Rs. 3310",
      "explanation": "A = 10000×(1.1)³ = 10000×1.331 = 13310. CI = 3310."
    }
  ]
}