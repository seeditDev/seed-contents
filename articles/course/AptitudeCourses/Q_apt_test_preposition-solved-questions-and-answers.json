      "id": "1",
      "question": "Fill in: She arrived ___ time for the meeting.",
      "options": [
        "at",
        "in",
        "on",
        "by"
      ],
      "correctAnswer": "on",
      "explanation": "'On time' means punctual. 'In time' means with time to spare."
    },
    {
