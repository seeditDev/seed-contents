  "questions": [
    {
      "id": "1",
      "question": "Find the 15th term of the AP: 2, 5, 8, 11, ...",
      "options": [
        "42",
        "44",
        "46",
        "48"
      ],
      "correctAnswer": "44",
      "explanation": "a=2, d=3. a15=2+(14×3)=2+42=44."
    },
    {
      "id": "2",
      "question": "The sum of first 10 terms of an AP with first term 3 and common difference 2 is:",
      "options": [
        "90",
        "100",
        "110",
        "120"
      ],
      "correctAnswer": "120",
      "explanation": "S10=10/2×(2×3+9×2)=5×(6+18)=5×24=120."
    },
    {
      "id": "3",
      "question": "Find the common ratio of GP: 3, 6, 12, 24, ...",
      "options": [
        "1",
        "2",
        "3",
        "4"
      ],
      "correctAnswer": "2",
      "explanation": "r = 6/3 = 2."
    },
    {
      "id": "4",
      "question": "The sum of first n terms of a GP with first term 2 and common ratio 3 is:",
      "options": [
        "(3ⁿ-1)",
        "(3ⁿ+1)",
        "3ⁿ-1",
        "(3ⁿ-1)/2"
      ],
      "correctAnswer": "(3ⁿ-1)",
      "explanation": "S=2×(3ⁿ-1)/(3-1)=3ⁿ-1."
    },
    {
      "id": "5",
      "question": "If 2, x, 18 are in GP, find x.",
      "options": [
        "5",
        "6",
        "7",
        "8"
      ],
      "correctAnswer": "6",
      "explanation": "x²=2×18=36. x=6."
    },
    {
      "id": "6",
      "question": "Find the 8th term of the GP: 1, 2, 4, 8, ...",
      "options": [
        "64",
        "128",
        "256",
        "512"
      ],
      "correctAnswer": "128",
      "explanation": "a8=1×2⁷=128."
    },
    {
      "id": "7",
      "question": "The sum of an infinite GP with first term 1 and common ratio 1/2 is:",
      "options": [
        "1",
        "1.5",
        "2",
        "2.5"
      ],
      "correctAnswer": "2",
      "explanation": "S = a/(1-r) = 1/(1-0.5) = 2."
    },
    {
      "id": "8",
      "question": "Which term of the AP 21, 18, 15, ... is 0?",
      "options": [
        "6",
        "7",
        "8",
        "9"
      ],
      "correctAnswer": "8",
      "explanation": "a=21, d=-3. 21+(n-1)×(-3)=0. n-1=7. n=8."
    },
    {
      "id": "9",
      "question": "Three numbers in AP have sum 21 and product 231. Find the numbers.",
      "options": [
        "3, 7, 11",
        "1, 7, 13",
        "5, 7, 9",
        "2, 7, 12"
      ],
      "correctAnswer": "3, 7, 11",
      "explanation": "a-d+a+a+d=3a=21, a=7. (7-d)×7×(7+d)=231. 7(49-d²)=231. 49-d²=33. d²=16. d=4. Numbers: 3,7,11."
    },
    {
      "id": "10",
      "question": "The product of three consecutive terms of a GP is 512. If 4 is added to the second term, they form an AP. Find the terms.",
      "options": [
        "4, 8, 16",
        "2, 8, 32",
        "1, 8, 64",
        "8, 8, 8"
      ],
      "correctAnswer": "4, 8, 16",
      "explanation": "Let a/r, a, ar. a³=512, a=8. 4/r, 12, 8r in AP → 24=4/r+8r. 8r²-24r+4=0. r=2 or r=1/4. Terms: 4, 8, 16."
    },
    {
      "id": "11",
      "question": "How many terms of the AP 1, 4, 7, ... are needed to give a sum of 715?",
      "options": [
        "11",
        "12",
        "13",
        "22"
      ],
      "correctAnswer": "22",
      "explanation": "S=n/2×(2+3(n-1))=n(3n-1)/2=715. 3n²-n-1430=0. n=22."
    },
    {
      "id": "12",
      "question": "In an AP, the sum of terms equidistant from the beginning and end is always equal to:",
      "options": [
        "sum of first and last",
        "twice the first",
        "twice the middle",
        "middle term"
      ],
      "correctAnswer": "sum of first and last",
      "explanation": "This is a fundamental property of APs."
    }
  ]
