      "question": "If 0.75:x = 5:8, then x equals:",
      "options": [
        "1.12",
        "1.20",
        "1.25",
        "1.30"
      ],
      "correctAnswer": "1.20",
      "explanation": "x = (0.75×8)/5 = 6/5 = 1.20."
