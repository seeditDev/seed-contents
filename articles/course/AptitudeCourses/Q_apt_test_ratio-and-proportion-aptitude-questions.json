      "question": "If A:B = 2:3 and B:C = 4:5, find A:C.",
      "options": [
        "6:15",
        "8:15",
        "2:5",
        "4:15"
      ],
      "correctAnswer": "8:15",
      "explanation": "A:C = (A/B)×(B/C) = (2/3)×(4/5) = 8/15."
    },
