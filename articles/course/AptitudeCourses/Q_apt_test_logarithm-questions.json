      "id": "1",
      "question": "What is log₂(32)?",
      "options": [
        "4",
        "5",
        "6",
        "7"
      ],
      "correctAnswer": "5",
      "explanation": "2⁵=32. log₂(32)=5."
    },
    {
      "id": "2",
      "question": "If log(2) = 0.3010, find log(200).",
      "options": [
        "2.001",
        "2.3010",
        "2.601",
        "2.699"
      ],
      "correctAnswer": "2.3010",
      "explanation": "log(200)=log(2×100)=log2+log100=0.3010+2=2.3010."
    },
    {
      "id": "3",
      "question": "Simplify: log₃(81) - log₃(3).",
      "options": [
        "1",
        "2",
        "3",
        "4"
      ],
      "correctAnswer": "3",
      "explanation": "log₃(81)=4, log₃(3)=1. 4-1=3."
    },
    {
      "id": "4",
      "question": "If log(x) = 2, then x =",
      "options": [
        "10",
        "20",
        "100",
        "200"
      ],
      "correctAnswer": "100",
      "explanation": "log₁₀(x)=2 means x=10²=100."
    },
    {
      "id": "5",
      "question": "What is the value of log₁₀(1)?",
      "options": [
        "0",
        "1",
        "-1",
        "undefined"
      ],
      "correctAnswer": "0",
      "explanation": "log(1)=0 because 10⁰=1."
    },
    {
      "id": "6",
      "question": "If log₃(x) = 4, find x.",
      "options": [
        "12",
        "27",
        "64",
        "81"
      ],
      "correctAnswer": "81",
      "explanation": "x=3⁴=81."
    },
    {
      "id": "7",
      "question": "log(ab) equals:",
      "options": [
        "log a + log b",
        "log a - log b",
        "log a × log b",
        "log a / log b"
      ],
      "correctAnswer": "log a + log b",
      "explanation": "Product rule: log(ab) = log a + log b."
    }
  ]
