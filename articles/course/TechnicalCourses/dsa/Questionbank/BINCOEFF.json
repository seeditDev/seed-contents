  "content": {
    "problemStatement": "Given two integers $n$, and $k$, find $\\binom{n}{k} = \\frac{n!}{k!(n-k)!}$. Output the answer modulo $10^9 + 7$.",
    "constraints": [
      "- $1 \\leq T \\leq 100$\n- $1 \\leq k \\leq n \\leq 10^6$"
    ],
    "inputFormat": "- The first line of input will contain a single integer $T$, denoting the number of test cases.\n- The only line of each test case consists of two integers - $n, k$.",
    "outputFormat": "For each test case, output on a new line the answer.",
    "sampleTestCases": [
      {
        "input": "3\n5 2\n5 3\n6 4\n",
        "output": "10\n10\n15\n",
        "explanation": "**Test case 1:** $\\frac{n!}{k!(n-k)!} = \\frac{5!}{2!* 3!} = \\frac{5*4}{2} = 10$\n\n**Test case 2:** $\\frac{n!}{k!(n-k)!} = \\frac{5!}{3! * 2!} = \\frac{5*4}{2} = 10$\n\n**Test case 3:** $\\frac{n!}{k!(n-k)!} = \\frac{6!}{4! * 2!} = \\frac{6*5}{2} = 15$"
      }
    ]
  },
