    "code": {
      "C": "#include <stdio.h>\n\nint main() {\n    int n;\n    scanf(\"%d\", &n);\n\n    for (int i = 1; i <= n; i++) {\n        if (i % 2 != 0)\n            continue;\n\n        printf(\"%d \", i);\n    }\n\n    printf(\"\\n\");\n\n    return 0;\n}\n"
