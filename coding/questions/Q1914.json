  "solution": {
    "approach": "",
    "timeComplexity": "",
    "spaceComplexity": "",
    "code": {
      "Java": "class Codechef\n{\n    public static void main (String[] args) \n    {\n        int[] values = {2, 10, 12, 6, 15};\n        for (int x : values) \n        {\n            if (x > 10) \n            {\n                continue;\n            }\n            System.out.print(x * x + \" \");\n        }        \n    }\n}"
