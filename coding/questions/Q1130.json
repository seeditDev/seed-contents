    "code": {
      "C++": "#include <iostream>\nusing namespace std;\n\nint main() {\n    int n;\n    cin>>n;\n    int arr[n];\n    for(int i = 0; i < n; i++){\n        cin >> arr[i];\n    }\n    int sum = 0;\n    int product = 1;\n    for(int i = 0; i < n; i++){\n        sum += arr[i];\n        product *= arr[i];\n    }\n    cout<< sum << \" \" << product <<\"\\n\";\n\n}\n"
