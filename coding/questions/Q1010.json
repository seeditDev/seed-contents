  "solution": {
    "approach": "",
    "timeComplexity": "",
    "spaceComplexity": "",
    "code": {
      "C": "#include <stdio.h>\n\nint main() {\n    int number, digit1, digit2, digit3;\n    scanf(\"%d\", &number);\n    digit1 = number % 10;\n    digit2 = (number / 10) % 10;\n    digit3 = number / 100;\n    printf(\"Digits in reverse order: %d %d %d\", digit1, digit2, digit3);\n    return 0;\n}\n"
