  "tcGeneratorPython": "def generate_case(i, RINT, POWER):\n    # Generate input for hidden testcase i (1-indexed).\n    # For this problem each testcase consists of a single integer T.\n    # We'll map i to a T value covering the designed range.\n    mapping = {\n        1: 1, 2: 2, 3: 3, 4: 4,\n        5: 10, 6: 9, 7: 8, 8: 7,\n        9: 5, 10: 6, 11: 2, 12: 3,\n        13: 1, 14: 10, 15: 4, 16: 5,\n        17: 6, 18: 7, 19: 8, 20: 9\n    }\n    t = mapping.get(i, 1)\n    print(t)"
