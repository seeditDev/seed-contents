    "code": {
      "Python3": "# Given dictionary\nstudent_grades = {\"Alice\": 85, \"Bob\": 72, \"Charlie\": 90, \"David\": 65, \"Eva\": 88, \"John\": 45}\n\n# Solution\nname = input()\nif name in student_grades:\n    print(student_grades[name])\nelse:\n    print(\"Not Found\")"
