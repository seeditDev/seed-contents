  "solution": {
    "approach": "",
    "timeComplexity": "",
    "spaceComplexity": "",
    "code": {
      "C": "#include <stdio.h>\n\nvoid swap(int *x, int *y) {\n    int temp = *x;\n    *x = *y;\n    *y = temp;\n}\n\nint main() {\n    int a, b;\n    scanf(\"%d %d\", &a, &b);\n    swap(&a, &b);\n    printf(\"%d %d\", a, b);\n    return 0;\n}"
