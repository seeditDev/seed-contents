    "code": {
      "C": "#include <stdio.h>\n\nint main() {\n    int n, sum = 0, i = 2;\n    scanf(\"%d\", &n);\n\n    while (i <= n) {\n        sum += i;\n        i += 2;\n    }\n\n    printf(\"%d\", sum);\n\n    return 0;\n}\n"
