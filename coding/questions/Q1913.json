    "code": {
      "Java": "class Codechef\n{\n    public static void main (String[] args) \n    {\n        int[] numbers = {2, 4, 8, 12, 8};\n        for (int i = 0; i < numbers.length; i++) \n        {\n            if (numbers[i] == 8) \n            {\n               System.out.println(i);\n               break;\n            }\n        }\n    }\n}\n"
