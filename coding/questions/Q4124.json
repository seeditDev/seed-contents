  "content": {
    "problemStatement": "Declare a variable **hour** and initialize it with the value 555 Then, calculate and print the total number of minutes and seconds present in this hour.",
    "constraints": [
      "1 <= T <= 10",
      "1 <= hour <= 1000",
      "All values are integers"
    ],
    "inputFormat": "First line contains an integer T, the number of test cases. Each of the next T lines contains a single integer hour.",
    "outputFormat": "For each test case, print two lines: the first line is the total number of minutes (hour × 60) and the second line is the total number of seconds (hour × 3600).",
    "sampleTestCases": [
      {
        "id": "sample_1",
        "input": "1\n555",
        "output": "33300\n1998000",
        "explanation": "hour = 555 → minutes = 555 × 60 = 33300, seconds = 555 × 3600 = 1998000."
      },
      {
        "id": "sample_2",
        "input": "1\n3",
        "output": "180\n10800",
        "explanation": "hour = 3 → minutes = 3 × 60 = 180, seconds = 3 × 3600 = 10800."
      },
      {
        "id": "sample_3",
        "input": "1\n120",
        "output": "7200\n432000",
        "explanation": "hour = 120 → minutes = 120 × 60 = 7200, seconds = 120 × 3600 = 432000."
      }
    ]
