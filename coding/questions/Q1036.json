    "code": {
      "C": "// Solution\n#include <stdio.h>\n\nint main() {\n    int a, b;\n    scanf(\"%d %d\", &a, &b);\n    int sum = a + b;\n    if(sum % 2 == 0)\n        printf(\"YES\");\n    else \n        printf(\"NO\");\n    return 0;\n}\n"
