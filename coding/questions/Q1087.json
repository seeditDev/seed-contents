  "solution": {
    "approach": "",
    "timeComplexity": "",
    "spaceComplexity": "",
    "code": {
      "C": "#include <stdio.h>\n\nint factorial(int n) {\n    if (n == 1) return 1;\n    return n*factorial(n-1);\n}\n\nint main() {\n    long long n;  \n    scanf(\"%d\", &n);\n    \n    printf(\"%lld\", factorial(n));\n    \n    return 0;\n}"
