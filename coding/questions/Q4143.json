  "solution": {
    "approach": "The task is to double each given integer. For every test case we read x and compute 2*x. No complex data structures are needed; a single pass over the input suffices.",
    "timeComplexity": "O(T) overall, O(1) per test case.",
    "spaceComplexity": "O(1) extra space besides input and output buffers.",
    "code": {
      "C": "",
      "C++": "",
      "Java": "import java.io.*;\n\npublic class Main {\n    public static void main(String[] args) throws IOException {\n        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));\n        StringBuilder sb = new StringBuilder();\n        int T = Integer.parseInt(br.readLine().trim());\n        for (int i = 0; i < T; i++) {\n            String line;\n            while ((line = br.readLine()) != null && line.trim().isEmpty()) {}\n            int x = Integer.parseInt(line.trim());\n            sb.append(x * 2);\n            if (i < T - 1) sb.append('\\n');\n        }\n        System.out.print(sb.toString());\n    }\n}",
      "Python3": "",
      "JavaScript": ""
    }
  },
