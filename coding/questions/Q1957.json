    "code": {
      "C++": "a, b, c = map(int, input().split())\n\nif a < b < c:\n    print(\"Increasing\")\nelif a > b > c:\n    print(\"Decreasing\")\nelse:\n    print(\"Neither\")\n",
      "Python3": "a, b, c = map(int, input().split())\n\nif a < b < c:\n    print(\"Increasing\")\nelif a > b > c:\n    print(\"Decreasing\")\nelse:\n    print(\"Neither\")\n"
