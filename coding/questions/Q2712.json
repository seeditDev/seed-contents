  "content": {
    "problemStatement": "The Chef is given a list of **N triangles**. Each triangle is identfied by the coordinates of its three corners in the 2-D cartesian plane. His job is to figure out **how many\nof the given triangles are right triangles**. A right triangle is a triangle in which one angle is a 90 degree angle. The vertices\nof the triangles have integer coordinates and all the triangles given are valid( three points aren't colinear ). &nbsp;\n\n&nbsp;",
    "constraints": [
      "**1** ≤ **N** ≤ **100000  (105)**",
      "**0** ≤ **x1, y1, x2, y2, x3, y3** ≤ **20**",
      "&nbsp;"
    ],
    "inputFormat": "**N****N****x1 y1 x2 y2 x3 y3****(x1, y1)****(x2, y2)****(x3, y3)**&nbsp;",
    "outputFormat": "&nbsp;",
    "sampleTestCases": [
      {
        "id": "sample_1",
        "input": "5\n0 5 19 5 0 0\n17 19 12 16 19 0\n5 14 6 13 8 7\n0 4 0 14 3 14\n0 2 0 14 9 2",
        "output": "3",
        "explanation": "Explanation:\nThe first triangle and the last two triangles of the example are right triangles."
      }
    ]
  },
