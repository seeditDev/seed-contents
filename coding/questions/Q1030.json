    "code": {
      "C": "#include <stdio.h>\n\nint main() {\n    int n;\n    scanf(\"%d\", &n);\n    int digit_sum = 0;\n    while(n > 0) {\n        digit_sum += n % 10;\n        n /= 10;\n    }\n    printf(\"%d\", digit_sum);\n}\n"
