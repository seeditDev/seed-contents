    "code": {
      "Java": "import java.util.Scanner;\npublic class Main {\n    public static void main(String[] args) {\n        Scanner scanner = new Scanner(System.in);\n        int t = scanner.nextInt();\n        while (t-- > 0) {\n            int N = scanner.nextInt();\n            System.out.println(N + 1);\n        }\n    }\n}"
