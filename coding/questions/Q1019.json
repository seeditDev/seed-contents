  "solution": {
    "approach": "",
    "timeComplexity": "",
    "spaceComplexity": "",
    "code": {
      "C": "#include <stdio.h>\n\nint main() {\n    int numbers[5];\n    int sum = 0;\n\n    // Input: Enter 5 integers\n    for (int i = 0; i < 5; i++) {\n        scanf(\"%d\", &numbers[i]);\n    }\n\n    // Calculate the sum of array elements\n    for (int i = 0; i < 5; i++) {\n        sum += numbers[i];\n    }\n\n    // Output: Print the sum\n    printf(\"%d\\n\", sum);\n\n    return 0;\n}\n"
    }
