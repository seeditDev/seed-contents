  "content": {
    "problemStatement": "Given an integer xxx, find two non-negative integers aaa and bbb such that (a∧b)+(a∨b)=x(a \\wedge b) + (a \\vee b) = x(a∧b)+(a∨b)=x, where ∧\\wedge∧ is the bitwise AND operation and ∨\\vee∨ is the bitwise OR operation.",
    "constraints": [
      "1 <= T <= 100000",
      "0 <= x <= 10^18"
    ],
    "inputFormat": "First line contains an integer T, the number of test cases. Each of the next T lines contains a single integer x.",
    "outputFormat": "For each test case, output two space-separated non‑negative integers a and b such that (a & b) + (a | b) = x. Print each pair on its own line.",
    "sampleTestCases": [
      {
        "id": "sample_1",
        "input": "2\n9\n12",
        "output": "0 9\n0 12",
        "explanation": "For x=9, a=0 and b=9 give (0&9)+(0|9)=0+9=9. For x=12, a=0 and b=12 give (0&12)+(0|12)=0+12=12."
      },
      {
        "id": "sample_2",
        "input": "1\n13",
        "output": "0 13",
        "explanation": "a=0, b=13 satisfy (0&13)+(0|13)=0+13=13."
      },
      {
        "id": "sample_3",
        "input": "1\n100",
        "output": "0 100",
        "explanation": "a=0, b=100 satisfy (0&100)+(0|100)=0+100=100."
      }
    ]
  },
