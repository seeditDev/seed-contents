  "content": {
    "problemStatement": "Write a program that uses a do-while loop to find the factorial of a given number.",
    "constraints": [
      "1 <= T <= 10",
      "1 <= N <= 100"
    ],
    "inputFormat": "First line contains an integer T (1 ≤ T ≤ 10), the number of test cases. Each of the next T lines contains a single integer N (1 ≤ N ≤ 100).",
    "outputFormat": "For each test case, output the factorial of N on its own line without leading zeros.",
