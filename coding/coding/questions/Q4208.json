  "content": {
    "problemStatement": "For a given NNN, find the number of ways to choose an integer xxx from the range [0,2N−1][0, 2^N - 1][0,2N−1] such that x⊕(x+1)=(x+2)⊕(x+3)x \\oplus (x+1) = (x+2) \\oplus (x+3)x⊕(x+1)=(x+2)⊕(x+3), where ⊕\\oplus⊕ denotes the bitwise XOR operator.\n\nSince the number of valid xxx can be large, output it modulo 109+710^9+7109+7.",
    "constraints": [
      "1 <= T <= 100000",
      "1 <= N <= 100000",
      "All values are integers"
    ],
    "inputFormat": "First line contains an integer T, the number of test cases. Each of the next T lines contains a single integer N (1 ≤ N ≤ 100000).",
    "outputFormat": "For each test case, output a single line containing the number of integers x in [0, 2^N‑1] that satisfy x⊕(x+1) = (x+2)⊕(x+3), modulo 1 000 000 007.",
    "sampleTestCases": [
      {
        "id": "sample_1",
        "input": "2\n1\n2",
        "output": "1\n2",
        "explanation": "For N=1 the range is [0,1]; only x=0 satisfies the equality. For N=2 the range is [0,3]; x=0 and x=2 satisfy."
      },
      {
        "id": "sample_2",
        "input": "3\n3\n4\n5",
        "output": "4\n8\n16",
        "explanation": "The answer follows 2^{N-1}: 2^{2}=4, 2^{3}=8, 2^{4}=16."
      },
      {
        "id": "sample_3",
        "input": "1\n30",
        "output": "536870912",
        "explanation": "2^{29}=536870912 which is less than the modulus, so the answer is unchanged."
      }
    ]
  },
