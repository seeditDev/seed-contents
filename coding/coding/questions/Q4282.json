  "tcGeneratorPython": "def generate_case(i, RINT, POWER):\n    # i: test case index (0‑based) up to 20\n    if i == 0:\n        print(1)\n        print(1)\n    elif i == 1:\n        print(1)\n        print(2)\n    elif i == 2:\n        print(1)\n        print(3)\n    elif i == 3:\n        print(1)\n        print(4)\n    elif i == 4:\n        print(1)\n        print(1000)\n    elif i == 5:\n        print(2)\n        print(1000)\n        print(999)\n    elif i == 6:\n        print(1)\n        print(15)\n    elif i == 7:\n        print(1)\n        print(14)\n    elif i == 8:\n        print(1)\n        print(9)\n    elif i == 9:\n        print(1)\n        print(8)\n    elif i == 10:\n        print(3)\n        print(1)\n        print(2)\n        print(3)\n    elif i == 11:\n        print(3)\n        print(3)\n        print(2)\n        print(1)\n    elif i == 12:\n        print(1)\n        print(999)\n    elif i == 13:\n        print(1)\n        print(998)\n    elif i == 14:\n        print(1)\n        print(101)\n    elif i == 15:\n        print(1)\n        print(997)\n    elif i == 16:\n        print(5)\n        for _ in range(5):\n            print(RINT(1,5))\n    elif i == 17:\n        print(4)\n        for n in (10,20,30,40):\n            print(n)\n    elif i == 18:\n        print(2)\n        print(500)\n        print(500)\n    elif i == 19:\n        print(3)\n        print(100)\n        print(200)\n        print(300)\n"
